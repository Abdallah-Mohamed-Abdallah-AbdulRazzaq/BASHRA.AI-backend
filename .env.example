# .env file for Bashra AI application

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=Katch@112481632
DB_PORT=3306
DB_DATABASE=bashra_ai

# Security
SECRET_KEY=123456789
SESSION_SECRET=123456789

# Server
PORT=3006
NODE_ENV=development
BACKEND_URL=http://localhost:3006
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:3006

EMAIL_USER=my_email
EMAIL_PASS=my_email_password

# SMS Configuration (RapidAPI)
RAPIDAPI_KEY=my_rapidapi_key

# Redis Configuration (Required for production)
# Redis is used for session storage in production
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0


DB_NAME=bashra_ai




# DB_NAME=bashraai_bashraai
# DB_DATABASE=bashraai_bashraai


AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
AI_ENABLE_IMAGE_ANALYSIS=true
AI_ENABLE_DOCUMENT_ANALYSIS=true
AI_REQUIRE_PATIENT_CONSENT=true
AI_DEFAULT_LANGUAGE=ar

OPENAI_API_KEY="MY_OPENAI_API_KEY"
AI_USE_MOCK=false
AI_TEMPERATURE=0.2