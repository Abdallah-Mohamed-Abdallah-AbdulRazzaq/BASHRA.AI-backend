{
  "info": {
    "name": "Doctor Verification Documents APIs",
    "description": "اختبار APIs مستندات التحقق للأطباء",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Upload Medical License",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{doctor_token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "document_type",
              "value": "medical_license",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": "/path/to/medical-license.pdf"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/profile-doctor/verification-documents",
          "host": ["{{base_url}}"],
          "path": ["api", "profile-doctor", "verification-documents"]
        },
        "description": "رفع رخصة مزاولة المهنة"
      },
      "response": []
    },
