          {
            "key": "Accept-Language",
            "value": "ar",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/admin/doctors/{{doctor_id}}/profile/complete",
          "host": ["{{base_url}}"],
          "path": ["api", "admin", "doctors", "{{doctor_id}}", "profile", "complete"]
        },
        "description": "جلب جميع بيانات الطبيب (حساب + ملف شخصي + ترجمات + مستندات)"
      },
      "response": []
