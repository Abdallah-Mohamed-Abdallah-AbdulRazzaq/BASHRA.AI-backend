  "postman_setup_instructions": {
    "step_1": {
      "title": "إنشاء Collection جديدة",
      "instructions": [
        "افتح Postman",
        "اضغط على 'New' ثم 'Collection'",
        "سمِّها 'Profile Doctor API Tests'"
      ]
    },
    "step_2": {
      "title": "إنشاء Environment",
      "instructions": [
        "اضغط على 'Environments' من القائمة الجانبية",
        "اضغط على 'Create Environment'",
        "سمِّها 'Doctor API Local'",
        "أضف المتغيرات: base_url, jwt_token, doctor_id"
      ]
    },
    "step_3": {
      "title": "الحصول على JWT Token",
      "instructions": [
        "أنشئ request جديد: POST {{base_url}}/api/auth-doctor/login",
        "في Body اختر 'raw' و 'JSON'",
        "أدخل: {\"email\": \"doctor@example.com\", \"password\": \"your_password\"}",
        "اضغط Send",
        "انسخ الـ token من الاستجابة",
        "ضعه في متغير jwt_token في Environment"
      ]
    },
    "step_4": {
      "title": "إنشاء Request للتحديث",
      "instructions": [
        "أنشئ request جديد في Collection",
        "اختر Method: PUT",
        "URL: {{base_url}}/api/profile-doctor",
        "في Headers أضف:",
        "  - Authorization: Bearer {{jwt_token}}",
        "  - Content-Type: application/json",
        "  - Accept-Language: ar",
        "في Body اختر 'raw' و 'JSON'",
        "انسخ أي test case من الملف أعلاه",
        "اضغط Send"
      ]
    },
    "step_5": {
      "title": "اختبار الـ Test Cases",
      "instructions": [
        "جرب كل test case على حدة",
        "تحقق من الاستجابة (status 200)",
        "تحقق من أن البيانات تم تحديثها",
        "استخدم GET /api/profile-doctor للتحقق من التحديثات"
      ]
    }
  },

  "common_errors_and_solutions": {
    "error_1": {
      "error": "401 Unauthorized",
      "cause": "JWT token غير صالح أو منتهي",
      "solution": "قم بتسجيل الدخول مرة أخرى واحصل على token جديد"
    },
    "error_2": {
      "error": "400 Bad Request - البريد الإلكتروني مستخدم بالفعل",
      "cause": "Email موجود لطبيب آخر",
      "solution": "استخدم email مختلف"
    },
    "error_3": {
      "error": "400 Bad Request - رقم الهاتف مستخدم بالفعل",
      "cause": "Phone موجود لطبيب آخر",
      "solution": "استخدم رقم هاتف مختلف"
    },
    "error_4": {
      "error": "404 Not Found - الملف الشخصي غير موجود",
      "cause": "لا يوجد profile للطبيب",
      "solution": "تأكد من أن الطبيب لديه profile في قاعدة البيانات"
    },
    "error_5": {
      "error": "500 Internal Server Error",
      "cause": "خطأ في السيرفر أو قاعدة البيانات",
      "solution": "تحقق من logs السيرفر وتأكد من اتصال قاعدة البيانات"
    }
  },

  "tips_and_best_practices": [
    "احفظ الـ test cases كـ requests منفصلة في Postman Collection",
    "استخدم Pre-request Scripts للحصول على token تلقائياً",
    "استخدم Tests tab لكتابة assertions تلقائية",
    "قم بعمل backup للـ Collection بعد إعدادها",
    "استخدم Variables لتسهيل تغيير البيانات",
    "جرب كل test case على حدة قبل الاختبار الشامل",
    "تحقق من البيانات بعد كل تحديث باستخدام GET endpoints"
  ]
}
