                  "pm.test('In-clinic schedules have clinic and location info', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 0) {",
                  "        jsonData.data.forEach(schedule => {",
                  "            if (schedule.consultation_type === 'in_clinic') {",
                  "                pm.expect(schedule.clinic).to.exist;",
                  "                pm.expect(schedule.clinic.name).to.exist;",
                  "                pm.expect(schedule.clinic.address).to.exist;",
                  "                // Location may or may not exist depending on region_id",
