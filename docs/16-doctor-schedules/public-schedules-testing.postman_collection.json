                  "    pm.expect(summary.working_days_count).to.exist;",
                  "    pm.expect(summary.online_schedules).to.exist;",
                  "    pm.expect(summary.in_clinic_schedules).to.exist;",
                  "    pm.expect(summary.price_range).to.exist;",
                  "    pm.expect(summary.price_range.min).to.exist;",
                  "    pm.expect(summary.price_range.max).to.exist;",
                  "    pm.expect(summary.price_range.avg).to.exist;",
