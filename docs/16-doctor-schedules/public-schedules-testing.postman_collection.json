                  "pm.test('All schedules are online', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 0) {",
                  "        jsonData.data.forEach(schedule => {",
                  "            pm.expect(schedule.consultation_type).to.equal('online');",
                  "        });",
                  "    }",
                  "});"
                ]
              }
            }
