{
  "info": {
    "name": "Public Doctor Schedules API - Testing",
    "description": "اختبارات شاملة لـ APIs جداول المواعيد العامة للأطباء",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3006/api",
      "type": "string"
    },
    {
      "key": "doctor_id",
      "value": "4",
      "type": "string"
    }
