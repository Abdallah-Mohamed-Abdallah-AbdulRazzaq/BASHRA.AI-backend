  "item": [
    {
      "name": "1. Basic Public APIs",
      "item": [
        {
          "name": "Get All Public Schedules",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Response has count', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.count).to.exist;",
                  "});",
                  "",
                  "pm.test('Schedule structure is correct', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 0) {",
                  "        const schedule = jsonData.data[0];",
                  "        pm.expect(schedule.id).to.exist;",
                  "        pm.expect(schedule.day_of_week).to.exist;",
                  "        pm.expect(schedule.start_time).to.exist;",
                  "        pm.expect(schedule.end_time).to.exist;",
                  "        pm.expect(schedule.session_price).to.exist;",
                  "        pm.expect(schedule.session_duration).to.exist;",
                  "        pm.expect(schedule.consultation_type).to.exist;",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "url": {
              "raw": "{{base_url}}/public/doctor-schedules/{{doctor_id}}",
              "host": ["{{base_url}}"],
              "path": ["public", "doctor-schedules", "{{doctor_id}}"]
            }
          }
        },
        {
          "name": "Get Public Schedules - Filter Online",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
