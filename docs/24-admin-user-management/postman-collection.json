        }
      ]
    },
    {
      "name": "5. Search Users",
      "item": [
        {
          "name": "Search by Name (Arabic)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/search?query=أحمد",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "أحمد"
                }
              ]
            }
          }
        },
        {
          "name": "Search by Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/search?email=example.com",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "search"],
              "query": [
                {
                  "key": "email",
                  "value": "example.com"
                }
              ]
            }
          }
        },
        {
          "name": "Search by Phone",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/search?phone=966501234567",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "search"],
              "query": [
                {
                  "key": "phone",
