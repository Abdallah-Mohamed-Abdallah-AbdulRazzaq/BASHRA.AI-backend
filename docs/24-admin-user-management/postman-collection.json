{
  "info": {
    "name": "Admin User Management API",
    "description": "Complete API collection for BASHRA.AI Admin User Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3006/api",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('jwt_token', jsonData.token);",
                  "    pm.collectionVariables.set('jwt_token', jsonData.token);",
                  "    console.log('Token saved:', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@bashra.ai\",\n  \"password\": \"your_password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth-admin/login",
              "host": ["{{base_url}}"],
              "path": ["auth-admin", "login"]
            }
          }
        }
      ]
    },

    {
      "name": "1. Get All Users",
      "item": [
        {
          "name": "Get All Users (Default)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"]
            }
          }
        },
        {
          "name": "Get All Users (Page 2, Limit 50)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users?page=2&limit=50",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                {
                  "key": "page",
                  "value": "2"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Users (Filter by Active Status)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users?status=active",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                {
                  "key": "status",
                  "value": "active"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Users (Filter by Verified)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users?verified=true",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                {
                  "key": "verified",
                  "value": "true"
                }
              ]
            }
          }
        }
      ]
    },

    {
      "name": "2. Get User By ID",
      "item": [
        {
          "name": "Get User By ID (Arabic)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}"]
            }
          }
        },
        {
          "name": "Get User By ID (English)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}?language=en",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}"],
              "query": [
                {
                  "key": "language",
                  "value": "en"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Get Users By Status",
      "item": [
        {
          "name": "Get Active Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/status/active",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "status", "active"]
            }
          }
        },
        {
          "name": "Get Suspended Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/status/suspended",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "status", "suspended"]
            }
          }
        },
        {
          "name": "Get Pending Verification Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/status/pending_verification",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "status", "pending_verification"]
            }
          }
        },
        {
          "name": "Get Inactive Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/status/inactive",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "status", "inactive"]
            }
          }
        }
      ]
    },

    {
      "name": "4. Get User Medical Profile",
      "item": [
        {
          "name": "Get Medical Profile (Arabic)",
          "request": {
            "method": "GET",
