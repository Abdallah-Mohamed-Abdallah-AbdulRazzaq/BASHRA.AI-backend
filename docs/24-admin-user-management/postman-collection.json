    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Invalid User ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/abc",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "abc"]
            }
          }
        },
        {
          "name": "User Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/99999",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "99999"]
            }
          }
        },
        {
          "name": "No JWT Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"]
            }
          }
        },
        {
          "name": "Invalid Status Value",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"invalid_status\",\n  \"reason\": \"Test reason for invalid status\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}", "status"]
            }
          }
        },
        {
          "name": "Reason Too Short",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"suspended\",\n  \"reason\": \"Short\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}", "status"]
            }
          }
        }
      ]
