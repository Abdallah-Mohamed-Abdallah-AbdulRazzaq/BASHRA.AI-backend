          "name": "Get All Logs for User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}/logs?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}", "logs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Filter Logs by Action",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}/logs?action=USER_STATUS_CHANGE",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}", "logs"],
              "query": [
