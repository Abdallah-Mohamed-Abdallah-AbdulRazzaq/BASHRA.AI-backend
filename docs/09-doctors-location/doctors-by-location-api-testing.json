    {
      "name": "3. Test Scenarios (سيناريوهات الاختبار)",
      "item": [
        {
          "name": "3.1 Complete Flow - Register Doctor & Add Address",
          "item": [
            {
              "name": "Step 1: Register Doctor",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"doctor.test@example.com\",\n  \"phone\": \"+966501234567\",\n  \"password\": \"Test@123456\",\n  \"license_number\": \"DOC-2024-001\",\n  \"years_of_experience\": 10,\n  \"full_name_ar\": \"د. أحمد محمد\",\n  \"full_name_en\": \"Dr. Ahmed Mohammed\",\n  \"specialty_ar\": \"طب القلب\",\n  \"specialty_en\": \"Cardiology\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/auth-doctor/register",
                  "host": ["{{base_url}}"],
                  "path": ["auth-doctor", "register"]
                }
              },
              "response": []
            },
            {
              "name": "Step 2: Login Doctor",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"doctor.test@example.com\",\n  \"password\": \"Test@123456\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/auth-doctor/login",
                  "host": ["{{base_url}}"],
                  "path": ["auth-doctor", "login"]
                },
                "description": "احفظ الـ token من الاستجابة في متغير {{doctor_token}}"
              },
              "response": []
            },
            {
              "name": "Step 3: Add Doctor Address",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{doctor_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"address_line1\": \"123 شارع الملك فهد\",\n  \"address_line2\": \"مبنى رقم 5\",\n  \"postal_code\": \"12345\",\n  \"countries_cities_id\": 2,\n  \"latitude\": 24.7136,\n  \"longitude\": 46.6753,\n  \"type\": \"work\",\n  \"is_primary\": true\n}"
                },
                "url": {
                  "raw": "{{base_url}}/addresses",
                  "host": ["{{base_url}}"],
                  "path": ["addresses"]
                }
              },
              "response": []
            },
            {
              "name": "Step 4: Search for Doctor by Location",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/doctors-by-location?countries_cities_id=2&lang=ar",
                  "host": ["{{base_url}}"],
                  "path": ["doctors-by-location"],
                  "query": [
                    {
                      "key": "countries_cities_id",
                      "value": "2"
                    },
                    {
                      "key": "lang",
                      "value": "ar"
                    }
                  ]
                },
                "description": "يجب أن يظهر الطبيب في النتائج"
              },
              "response": []
            }
          ],
          "description": "سيناريو كامل لاختبار التدفق من التسجيل حتى البحث"
        }
      ]
    }
