          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userAccessToken}}",
                "description": "Using old token that should be revoked"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth-user/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["auth-user", "sessions"]
            },
