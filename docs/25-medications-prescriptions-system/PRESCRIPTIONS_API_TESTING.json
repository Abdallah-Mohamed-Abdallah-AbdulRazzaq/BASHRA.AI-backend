              "mode": "raw",
              "raw": "{\n  \"dosage\": \"500mg\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/prescriptions/{{prescriptionId}}", "host": ["{{baseUrl}}"], "path": ["prescriptions", "{{prescriptionId}}"]},
            "description": "خطأ: المريض لا يمكنه التعديل\nError: Patient cannot update"
          }
        },
        {
          "name": "❌ Update Non-existent",
          "request": {
            "method": "PUT",
