            "body": {
              "mode": "raw",
              "raw": "{\n  \"dosage\": \"1000mg\",\n  \"frequency\": \"مرتين يومياً\",\n  \"duration\": \"10 أيام\",\n  \"quantity\": \"20 كبسولة\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/prescriptions/{{prescriptionId}}", "host": ["{{baseUrl}}"], "path": ["prescriptions", "{{prescriptionId}}"]},
