            },
            "url": {"raw": "{{baseUrl}}/prescriptions/99999", "host": ["{{baseUrl}}"], "path": ["prescriptions", "99999"]},
            "description": "خطأ: وصفة غير موجودة\nError: Prescription not found"
          }
        }
      ]
    },
    {
      "name": "Cancel Prescription | إلغاء وصفة",
      "item": [
        {
          "name": "✅ Doctor - Cancel Prescription",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Authorization", "value": "Bearer {{doctorToken}}"}],
            "url": {"raw": "{{baseUrl}}/prescriptions/{{prescriptionId}}/cancel", "host": ["{{baseUrl}}"], "path": ["prescriptions", "{{prescriptionId}}", "cancel"]},
            "description": "الطبيب يلغي وصفة\nDoctor cancels prescription"
          }
        },
        {
          "name": "❌ Patient Cannot Cancel",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Authorization", "value": "Bearer {{patientToken}}"}],
            "url": {"raw": "{{baseUrl}}/prescriptions/{{prescriptionId}}/cancel", "host": ["{{baseUrl}}"], "path": ["prescriptions", "{{prescriptionId}}", "cancel"]},
            "description": "خطأ: المريض لا يمكنه الإلغاء\nError: Patient cannot cancel"
          }
        },
        {
          "name": "❌ Cancel Already Cancelled",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Authorization", "value": "Bearer {{doctorToken}}"}],
            "url": {"raw": "{{baseUrl}}/prescriptions/{{prescriptionId}}/cancel", "host": ["{{baseUrl}}"], "path": ["prescriptions", "{{prescriptionId}}", "cancel"]},
            "description": "خطأ: وصفة ملغاة بالفعل\nError: Already cancelled"
          }
        }
      ]
    },
