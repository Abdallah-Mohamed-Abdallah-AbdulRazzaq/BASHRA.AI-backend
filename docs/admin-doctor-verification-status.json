{
  "info": {
    "name": "Admin Doctor Verification Status API",
    "description": "اختبار API لتحديث حالة التحقق الشاملة للأطباء من قبل الأدمن",
    "_postman_id": "verification-status-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Update Doctor Verification Status - Verify & Approve",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}",
            "description": "توكن الأدمن"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept-Language",
            "value": "ar",
            "description": "اللغة المفضلة"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"is_verified\": true,\n  \"approval_status\": \"approved\",\n  \"reason\": \"تم التحقق من جميع المستندات والبيانات المهنية\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/admin/doctors/:doctorId/verification-status",
          "host": ["{{base_url}}"],
          "path": ["api", "admin", "doctors", ":doctorId", "verification-status"],
          "variable": [
            {
              "key": "doctorId",
              "value": "1",
              "description": "معرف الطبيب"
            }
          ]
        },
        "description": "تحديث حالة التحقق للطبيب - التحقق والموافقة\n\nيقوم بتحديث:\n- is_verified = true\n- verification_date = الوقت الحالي\n- verified_by = معرف الأدمن\n- approval_status = approved\n- doctor status = active"
      },
      "response": []
    },
