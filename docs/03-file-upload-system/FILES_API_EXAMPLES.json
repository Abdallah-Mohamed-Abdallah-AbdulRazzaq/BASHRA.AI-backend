    "prescription": "وصفة طبية",
    "license": "رخصة (رخصة طبيب، ترخيص، إلخ)",
    "id_document": "وثيقة هوية",
    "other": "أخرى"
  },
  "virus_scan_statuses": {
    "pending": "في انتظار الفحص",
    "clean": "نظيف (لا فيروسات)",
    "infected": "مصاب بفيروس",
    "error": "خطأ في الفحص"
  },
  "storage_providers": {
    "local": "تخزين محلي على السيرفر",
    "s3": "Amazon S3",
    "azure": "Microsoft Azure Storage",
    "gcs": "Google Cloud Storage"
  },
  "common_errors": [
    {
      "status": 404,
      "message": "File not found",
      "description": "الملف غير موجود أو محذوف"
    },
    {
      "status": 400,
      "message": "Please provide an array of UUIDs",
      "description": "في bulk delete - يجب إرسال array من UUIDs"
    },
    {
      "status": 401,
      "message": "Unauthorized",
      "description": "لم يتم المصادقة أو التوكن غير صحيح"
    },
    {
      "status": 403,
      "message": "Forbidden - Admin access required",
      "description": "يتطلب صلاحيات Admin"
    },
    {
      "status": 500,
      "message": "Error retrieving files",
      "description": "خطأ في السيرفر"
    }
  ],
  "integration_examples": {
    "profile_picture_upload": {
      "description": "عند رفع صورة شخصية، يتم تسجيلها تلقائياً في جدول files",
      "endpoint": "POST /api/profile-user/picture",
      "result": "يتم إنشاء سجل في files table مع file_category='profile_picture' و related_to_type='user_profile'"
    },
    "medical_record_images": {
      "description": "رفع صور طبية لسجل طبي",
      "code_example": {
        "javascript": "const FileService = require('./services/fileService');\n\nconst fileRecord = await FileService.uploadFile(\n  req.file,\n  { entityType: 'doctor', entityId: doctorId },\n  {\n    fileCategory: 'medical_image',\n    relatedToType: 'medical_record',\n    relatedToId: medicalRecordId,\n    isPublic: false,\n    metadata: {\n      body_part: 'chest',\n      image_type: 'x-ray'\n    }\n  }\n);"
      }
    }
  },
  "postman_collection_url": "Import this JSON into Postman as a collection",
  "notes": [
    "جميع endpoints تتطلب Admin authentication",
    "التواريخ بصيغة ISO 8601",
    "الأحجام بالـ bytes",
    "UUID format: 8-4-4-4-12 hexadecimal",
    "soft delete يعني is_deleted=1 (البيانات تبقى في القاعدة)",
    "hard delete يعني حذف من القرص والقاعدة"
  ]
}
