        },
        {
          "name": "Block Admin (Super Admin Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": 2,\n  \"entity_type\": \"admin\",\n  \"block_type\": \"permanent\",\n  \"reason\": \"إساءة استخدام صلاحيات الأدمن\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/blocked-entities/block",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "blocked-entities", "block"]
            }
          }
        }
      ]
    },
    {
      "name": "Unblock Operations",
      "item": [
        {
          "name": "Unblock Entity",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": 1,\n  \"entity_type\": \"user\",\n  \"reason\": \"تم مراجعة الحالة وإلغاء الحظر\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/blocked-entities/unblock",
