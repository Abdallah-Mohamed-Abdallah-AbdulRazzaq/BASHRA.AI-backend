            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": 1,\n  \"entity_type\": \"user\",\n  \"block_type\": \"warning\",\n  \"reason\": \"تحذير أول بسبب سلوك غير لائق\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/blocked-entities/block",
