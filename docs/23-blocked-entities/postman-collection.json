            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": 1,\n  \"entity_type\": \"doctor\",\n  \"block_type\": \"temporary\",\n  \"blocked_until\": \"2025-01-30T00:00:00.000Z\",\n  \"reason\": \"شكاوى متعددة من المرضى\"\n}"
