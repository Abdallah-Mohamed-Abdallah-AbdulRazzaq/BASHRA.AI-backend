    {
      "name": "Bulk Operations",
      "item": [
        {
          "name": "Bulk Block Entities",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entities\": [\n    { \"entity_id\": 1, \"entity_type\": \"user\" },\n    { \"entity_id\": 2, \"entity_type\": \"user\" },\n    { \"entity_id\": 3, \"entity_type\": \"user\" }\n  ],\n  \"block_type\": \"temporary\",\n  \"blocked_until\": \"2025-02-01T00:00:00.000Z\",\n  \"reason\": \"حظر جماعي بسبب نشاط مشبوه\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/blocked-entities/bulk/block",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "blocked-entities", "bulk", "block"]
            }
