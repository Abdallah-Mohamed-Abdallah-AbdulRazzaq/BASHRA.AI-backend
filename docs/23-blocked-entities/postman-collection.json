              "raw": "{\n  \"entities\": [\n    { \"entity_id\": 1, \"entity_type\": \"user\" },\n    { \"entity_id\": 2, \"entity_type\": \"user\" }\n  ],\n  \"reason\": \"إلغاء حظر جماعي\"\n}"
            },
            "url": {
