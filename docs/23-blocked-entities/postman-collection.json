              },
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": 1,\n  \"entity_type\": \"assistant\",\n  \"block_type\": \"temporary\",\n  \"blocked_until\": \"2025-01-20T00:00:00.000Z\",\n  \"reason\": \"عدم الالتزام بمواعيد العمل\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/blocked-entities/block",
