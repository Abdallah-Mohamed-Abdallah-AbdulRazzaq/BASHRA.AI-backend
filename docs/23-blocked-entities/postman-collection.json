            }
          }
        }
      ]
    },
    {
      "name": "Update Operations",
      "item": [
        {
          "name": "Update Block Record",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"block_type\": \"permanent\",\n  \"blocked_until\": null,\n  \"reason\": \"تحويل إلى حظر دائم بسبب تكرار المخالفات\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/blocked-entities/{{blockId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "blocked-entities", "{{blockId}}"]
            }
          }
        },
        {
          "name": "Extend Temporary Block",
          "request": {
            "method": "PATCH",
