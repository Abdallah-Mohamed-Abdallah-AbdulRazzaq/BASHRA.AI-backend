{
  "info": {
    "name": "Chat System Complete Testing",
    "description": "Comprehensive testing collection for Chat and Conversations system including Socket.IO events",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3006/api",
      "type": "string"
    },
    {
      "key": "socket_url",
      "value": "http://localhost:3006",
      "type": "string"
    },
    {
      "key": "user_token",
      "value": "",
      "type": "string",
      "description": "Patient/User token"
    },
    {
      "key": "doctor_token",
      "value": "",
      "type": "string",
      "description": "Doctor token"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string",
      "description": "Admin token"
    },
    {
      "key": "conversation_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "recipient_id",
      "value": "4",
      "type": "string",
      "description": "ID of the recipient (doctor/user)"
