  "item": [
    {
      "name": "Chat Users",
      "item": [
        {
          "name": "1. Get All Chat Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/chat-users",
              "host": ["{{base_url}}"],
              "path": ["chat-users"]
            },
            "description": "Get all available users for chat (excluding current user)"
          }
        },
        {
          "name": "2. Get Users by Type (Doctors)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/chat-users?type=doctor",
              "host": ["{{base_url}}"],
              "path": ["chat-users"],
              "query": [
                {
                  "key": "type",
                  "value": "doctor"
                }
              ]
            },
            "description": "Filter users by type: doctor"
          }
        },
        {
          "name": "3. Get Users by Type (Patients)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/chat-users?type=user",
              "host": ["{{base_url}}"],
              "path": ["chat-users"],
              "query": [
                {
                  "key": "type",
                  "value": "user"
                }
              ]
            },
            "description": "Filter users by type: user (patients)"
          }
        },
        {
          "name": "4. Search Users by Name",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/chat-users?search=أحمد",
              "host": ["{{base_url}}"],
              "path": ["chat-users"],
              "query": [
                {
                  "key": "search",
                  "value": "أحمد"
                }
              ]
            },
            "description": "Search users by name or email"
          }
        },
        {
          "name": "5. Search Doctors with Filter",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/chat-users?type=doctor&search=د",
              "host": ["{{base_url}}"],
              "path": ["chat-users"],
              "query": [
                {
                  "key": "type",
                  "value": "doctor"
                },
                {
                  "key": "search",
                  "value": "د"
                }
              ]
            },
            "description": "Search doctors by name"
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "1. Get All My Conversations",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.conversations && response.conversations.length > 0) {",
                  "        pm.collectionVariables.set('conversation_id', response.conversations[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/conversations",
              "host": ["{{base_url}}"],
              "path": ["conversations"]
            },
            "description": "Get all conversations for current user, sorted by last message"
          }
        },
        {
          "name": "2. Create New Conversation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.conversation) {",
                  "        pm.collectionVariables.set('conversation_id', response.conversation.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipient_id\": {{recipient_id}},\n  \"recipient_type\": \"{{recipient_type}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/conversations",
              "host": ["{{base_url}}"],
              "path": ["conversations"]
            },
            "description": "Create a new conversation with a recipient"
          }
        },
        {
          "name": "3. Get Conversation by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/conversations/{{conversation_id}}",
              "host": ["{{base_url}}"],
              "path": ["conversations", "{{conversation_id}}"]
            },
            "description": "Get details of a specific conversation"
          }
        },
        {
          "name": "4. Get Conversation Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/conversations/{{conversation_id}}/messages?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Get message history for a conversation with pagination"
          }
        },
        {
          "name": "5. Get Messages - Page 2",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/conversations/{{conversation_id}}/messages?limit=50&offset=50",
              "host": ["{{base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "50"
                }
              ]
            },
            "description": "Get second page of messages"
          }
        },
        {
          "name": "6. Get Recent Messages (Last 20)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/conversations/{{conversation_id}}/messages?limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Get last 20 messages"
          }
        }
      ]
    },
