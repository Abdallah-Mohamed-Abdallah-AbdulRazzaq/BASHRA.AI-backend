            "type": "text"
          },
          {
            "key": "Accept-Language",
            "value": "ar",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/doctor/appointments/{{appointment_id}}",
          "host": ["{{base_url}}"],
          "path": ["doctor", "appointments", "{{appointment_id}}"]
        },
        "description": "Get single appointment details"
      },
      "response": []
    },
