        },
        "url": {
          "raw": "{{base_url}}/admin/appointments/{{appointment_id}}/cancel",
          "host": ["{{base_url}}"],
          "path": ["admin", "appointments", "{{appointment_id}}", "cancel"]
        },
        "description": "Cancel an appointment with optional reason"
      },
      "response": []
    },
    {
      "name": "6. Delete Appointment",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has success true\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}",
            "type": "text"
          },
          {
            "key": "Accept-Language",
            "value": "ar",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/admin/appointments/{{appointment_id}}",
          "host": ["{{base_url}}"],
          "path": ["admin", "appointments", "{{appointment_id}}"]
        },
        "description": "Permanently delete an appointment"
      },
      "response": []
    },
    {
      "name": "7. Get Statistics",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has success true\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "",
              "pm.test(\"Statistics contain required fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('total_appointments');",
              "    pm.expect(jsonData.data).to.have.property('by_status');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}",
            "type": "text"
          },
          {
            "key": "Accept-Language",
            "value": "ar",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/admin/appointments/statistics?from_date=2026-03-01&to_date=2026-03-31",
          "host": ["{{base_url}}"],
          "path": ["admin", "appointments", "statistics"],
          "query": [
            {
              "key": "from_date",
              "value": "2026-03-01",
              "description": "Optional start date"
            },
            {
              "key": "to_date",
              "value": "2026-03-31",
              "description": "Optional end date"
            },
            {
              "key": "doctor_id",
              "value": "1",
              "description": "Optional doctor filter",
              "disabled": true
            }
          ]
        },
        "description": "Get appointment statistics"
      },
      "response": []
    }
  ]
}
